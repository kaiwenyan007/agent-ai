# 复制为 application-local.yml（已 gitignore），覆盖数据库与 API 等敏感配置
# 启动：mvn -pl agent-server spring-boot:run -Dspring-boot.run.profiles=dev,local

spring:
  datasource:
    url: jdbc:mysql://你的主机:3306/agent_ai?useUnicode=true&characterEncoding=utf8&serverTimezone=Asia/Shanghai
    username: 你的用户名
    password: 你的密码

agent:
  llm:
    api-key: sk-xxx
    base-url: https://api.deepseek.com
    model: deepseek-chat
  cli:
    llm:
      api-key: sk-xxx
      base-url: https://api.deepseek.com
      model: deepseek-chat
